{
  "name": "tonscript",
  "version": "0.1.0",
  "description": "TypeScript-like language that compiles directly to TVM bytecode",
  "type": "module",
  "bin": {
    "tonscript": "./dist/cli.js",
    "tonsc": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "tonscript": "npx tsx src/cli.ts",
    "tonsc": "npx tsx src/cli.ts",
    "test": "npx tsx src/cli.ts test",
    "test:unit": "npx tsx src/test.ts"
  },
  "dependencies": {
    "@ton/core": "^0.63.1",
    "@ton/ton": "^16.2.2"
  },
  "devDependencies": {
    "@ton/sandbox": "^0.41.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
